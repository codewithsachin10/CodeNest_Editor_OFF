# ═══════════════════════════════════════════════════
# CodeNest Studio — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════

# Supabase project URL (e.g. https://abcdefghijklmn.supabase.co)
SUPABASE_URL=

# Supabase service_role key (for uploading — KEEP SECRET, never commit!)
# Found in: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_KEY=

# Optional: release notes for the current version
RELEASE_NOTES=

# Optional: custom storage bucket name (default: "releases")
# STORAGE_BUCKET=releases
